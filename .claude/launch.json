{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Django Dev Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["manage.py", "runserver", "0.0.0.0:8000"],
      "port": 8000
    },
    {
      "name": "Celery Worker",
      "runtimeExecutable": "celery",
      "runtimeArgs": ["-A", "nebulux", "worker", "--loglevel=info"],
      "port": null
    },
    {
      "name": "Celery Beat Scheduler",
      "runtimeExecutable": "celery",
      "runtimeArgs": ["-A", "nebulux", "beat", "--loglevel=info"],
      "port": null
    },
    {
      "name": "Redis",
      "runtimeExecutable": "redis-server",
      "runtimeArgs": [],
      "port": 6379
    }
  ]
}
