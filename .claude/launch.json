{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Django Dev Server",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd backend && python manage.py runserver 0.0.0.0:8000"],
      "port": 8000
    },
    {
      "name": "Celery Worker",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd backend && celery -A nebulux worker --loglevel=info"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "Celery Beat Scheduler",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd backend && celery -A nebulux beat --loglevel=info"],
      "port": 3002,
      "autoPort": false
    },
    {
      "name": "Redis",
      "runtimeExecutable": "redis-server",
      "runtimeArgs": [],
      "port": 6379
    }
  ]
}
